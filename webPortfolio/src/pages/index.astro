---
import "../styles/index.css"

const name = "Brian Ramirez";
const title = "Full Stack Developer";

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{name} Portfolio</title>
	</head>
	<body>

		<!-- Navigation Sectiion -->
		<nav>
			<div class="container">
				<div class="logo">BR</div>
				<ul class="nav-links">
					<li><a href="#home">Home</a></li>
					<li><a href="#skills">Skills</a></li>
					<li><a href="#projects">Projects</a></li>
					<li><a href="#contact">Contact</a></li>
				</ul>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="hero" id="home">
			<div class="container">
				<div class="hero-content">
					<div class="hero-text fade-in">
						<h1>Hi, I'm <span class="highlight">{name}</span></h1>
						<p>{title} passionate about creating exceptional digital experiences with modern web technologies.</p>
						<div class="cta-buttons">
							<a href="#projects" class="btn-primary">View My Work</a>
							<a href="#projects" class="btn-secondary">Let's Talk</a>
						</div>
					</div>
					<div class="hero-visual fade-in stagger-2">
						<div class="code-window">
							<div class="code-content">
								<div class="code-line"><span class="keyword">const</span> <span class="function">developer</span> =  &lbrace;</div>
								<div class="code-line"> name: <span class="string">'Brian Ramirez'</span></div>
								<div class="code-line"> skills: [<span class="string">'JavaScript'</span>, <span class="string">'HTML'</span>, <span class="string">'CSS'</span>]</div>
								<div class="code-line"> passion: <span class="string">'Building amazing apps'</span></div>
								<div class="code-line"> <span class="function">code</span>: () =&gt; <span class="string">'coffee + code = magic'</span></div>
								<div class="code-line">&rbrace;;</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Skills Section -->
		<section class="skills" id="skills">
			<div class="container">
				<h2 class="section-title fade-in">Skills & Technologies</h2>
				<div class="skills-grid">
					<div class="skill-category fade-in stagger-1">
						<h3>Frontend Development</h3>
						<div class="tech-tags">
							<span class="tech-tag">React</span>
							<span class="tech-tag">TypeScript</span>
							<span class="tech-tag">Tailwind CSS</span>
							<span class="tech-tag">Sass</span>
							<span class="tech-tag">Bootstrap</span>
							<span class="tech-tag">JavaScript</span>
							<span class="tech-tag">Astro</span>
						</div>
						<div class="skill-category fade-in stagger-2">
							<h3>Backend Development</h3>
							<div class="tech-tags">
								<span class="tech-tag">Python</span>
								<span class="tech-tag">PHPMyAdmin</span>
								<span class="tech-tag">Oracle DB</span>
								<span class="tech-tag">MySQL</span>
							</div>
						</div>
						<div class="skill-category fade-in stagger-3">
							<div class="tech-tags">
								<span class="tech-tag">Git</span>
								<span class="tech-tag">SQL</span>
								<span class="tech-tag">CLI</span>
								<span class="tech-tag">UNIX</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Section -->
		<section class="projects" id="projects">
			<div class="container">
				<h2 class="section-title fade-in">Featured Projects</h2>
			</div>
		</section>
	</body>
</html>
